// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  SUPER_ADMIN // Admin utama pembuat SaaS
  TENANT_ADMIN // Manajer Gudang Klien
  PURCHASING
  RESOURCES
  WAREHOUSE_OPERATOR // Area Operator Gudang
  FINANCE
  PRODUCTION
  SHIPMENT
}

enum ProductCategory {
  RAW_MATERIAL
  WIP
  SUPPLY
  PACKAGING_MATERIAL
  FINISHED_GOOD
  FINISHED_PART
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT // Untuk Stock Opname
}

// --- MODELS ---

model Tenant {
  id         String   @id @default(uuid())
  name       String
  status     String   @default("active")
  created_at DateTime @default(now())

  // Relasi ke tabel lain (One-to-Many)
  users        User[]
  products     Product[]
  warehouses   Warehouse[]
  batches      InventoryBatch[]
  transactions TransactionLog[]
}

model User {
  id         String   @id @default(uuid())
  tenant_id  String // Isolasi data antar klien
  email      String   @unique
  password   String // Akan di-hash pakai bcrypt
  name       String
  role       Role     @default(WAREHOUSE_OPERATOR)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
}

model Product {
  id         String          @id @default(uuid())
  tenant_id  String
  sku        String // Stock Keeping Unit / Kode Barang
  name       String
  category   ProductCategory
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  tenant       Tenant           @relation(fields: [tenant_id], references: [id])
  batches      InventoryBatch[]
  transactions TransactionLog[]

  @@unique([tenant_id, sku]) // SKU tidak boleh sama dalam 1 perusahaan
  @@index([tenant_id])
}

model Warehouse {
  id          String @id @default(uuid())
  tenant_id   String
  name        String
  type        String @default("Private") // Public, Private, Contract, Multi Client
  layout_type String @default("Garis Lurus Sederhana") // Garis Lurus, U Shape, L Shape, Random

  tenant   Tenant     @relation(fields: [tenant_id], references: [id])
  locations Location[]

  @@index([tenant_id])
}

model Location {
  id           String @id @default(uuid())
  warehouse_id String
  name         String // Contoh: Rak-A1-01, Pallet-B2
  type         String // Racking atau Palleting

  warehouse Warehouse        @relation(fields: [warehouse_id], references: [id])
  batches   InventoryBatch[]
}

model InventoryBatch {
  id           String    @id @default(uuid())
  tenant_id    String // Wajib untuk isolasi data antar klien
  product_id   String
  location_id  String // Racking/Palleting
  quantity     Int
  entry_date   DateTime  @default(now()) // Mesin untuk FIFO/LIFO
  expiry_date  DateTime? // Mesin untuk FEFO
  cost_per_unit Decimal // Untuk perhitungan AVG/BPP

  tenant       Tenant           @relation(fields: [tenant_id], references: [id])
  product      Product          @relation(fields: [product_id], references: [id])
  location     Location         @relation(fields: [location_id], references: [id])
  transactions TransactionLog[]

  @@index([tenant_id])
  @@index([product_id])
}

model TransactionLog {
  id         String          @id @default(uuid())
  tenant_id  String
  product_id String
  batch_id   String?
  type       TransactionType
  quantity   Int // Jumlah keluar/masuk/penyesuaian
  notes      String? // Identitas DO, No. Resi, dll
  created_at DateTime        @default(now())

  tenant  Tenant          @relation(fields: [tenant_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  batch   InventoryBatch? @relation(fields: [batch_id], references: [id])

  @@index([tenant_id])
  @@index([product_id])
}