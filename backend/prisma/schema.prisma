generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  PURCHASING
  RESOURCES
  WAREHOUSE_OPERATOR
  FINANCE
  PRODUCTION
  SHIPMENT
}

enum ProductCategory {
  RAW_MATERIAL
  WIP
  SUPPLY
  PACKAGING_MATERIAL
  FINISHED_GOOD
  FINISHED_PART
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// --- MODELS ---

model Tenant {
  id         String   @id @default(uuid())
  name       String
  status     String   @default("active")
  created_at DateTime @default(now())

  users        User[]
  products     Product[]
  warehouses   Warehouse[]
  batches      InventoryBatch[]
  transactions TransactionLog[]
  auditLogs    AuditLog[]
}

model User {
  id         String   @id @default(uuid())
  tenant_id  String
  email      String   @unique
  password   String
  name       String
  role       Role     @default(WAREHOUSE_OPERATOR)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenant_id], references: [id])
  auditLogs AuditLog[]

  @@index([tenant_id])
}

model Product {
  id         String          @id @default(uuid())
  tenant_id  String
  sku        String
  name       String
  category   ProductCategory
  unit       String // Pcs, Box, Kg, dll
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  tenant       Tenant           @relation(fields: [tenant_id], references: [id])
  batches      InventoryBatch[]
  transactions TransactionLog[]

  @@unique([tenant_id, sku])
  @@index([tenant_id])
}

model Warehouse {
  id          String  @id @default(uuid())
  tenant_id   String
  name        String
  type        String  @default("Private")
  method      String  @default("FIFO")
  layout_type String  @default("Garis Lurus Sederhana")
  address     String?

  tenant    Tenant     @relation(fields: [tenant_id], references: [id])
  locations Location[]

  @@index([tenant_id])
}

model Location {
  id           String @id @default(uuid())
  warehouse_id String
  zone         String // Zone A, Zone B
  rack         String // Baris Rak
  shelf        String // Level Rak
  bin          String // Kode Palet/Bin

  warehouse Warehouse        @relation(fields: [warehouse_id], references: [id])
  batches   InventoryBatch[]
}

model InventoryBatch {
  id            String    @id @default(uuid())
  tenant_id     String
  product_id    String
  location_id   String
  quantity      Int
  batch_no      String?
  entry_date    DateTime  @default(now())
  expiry_date   DateTime?
  cost_per_unit Decimal

  tenant       Tenant           @relation(fields: [tenant_id], references: [id])
  product      Product          @relation(fields: [product_id], references: [id])
  location     Location         @relation(fields: [location_id], references: [id])
  transactions TransactionLog[]

  @@index([tenant_id])
  @@index([product_id])
}

model TransactionLog {
  id         String          @id @default(uuid())
  tenant_id  String
  product_id String
  batch_id   String?
  type       TransactionType
  quantity   Int
  notes      String?
  created_at DateTime        @default(now())

  tenant  Tenant          @relation(fields: [tenant_id], references: [id])
  product Product         @relation(fields: [product_id], references: [id])
  batch   InventoryBatch? @relation(fields: [batch_id], references: [id])

  @@index([tenant_id])
  @@index([product_id])
}

model AuditLog {
  id         String      @id @default(uuid())
  tenant_id  String
  user_id    String
  action     AuditAction
  entity     String // Nama tabel, misal: 'Product', 'InventoryBatch'
  old_data   Json? // Data sebelum diubah
  new_data   Json? // Data setelah diubah
  created_at DateTime    @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([user_id])
}
